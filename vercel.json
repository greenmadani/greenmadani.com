{
  "buildCommand": "cd artifacts/api-server && node build.mjs && cd ../gmi-website && pnpm run build",
  "outputDirectory": "artifacts/gmi-website/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...slug]"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
