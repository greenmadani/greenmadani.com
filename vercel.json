{
  "buildCommand": "cd artifacts/gmi-website && pnpm run build",
  "outputDirectory": "artifacts/gmi-website/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://gmi-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
