{
  "buildCommand": "cd artifacts/gmi-website && pnpm run build",
  "outputDirectory": "artifacts/gmi-website/dist/public",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
